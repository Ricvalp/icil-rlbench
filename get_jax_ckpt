#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  ./get_jax_ckpt RUN_ID STEP

Examples:
  ./get_jax_ckpt 23nyfa9u 0267000
  ./get_jax_ckpt 23nyfa9u 267000
  ./get_jax_ckpt 23nyfa9u step_0267000.pkl

Environment overrides:
  ICIL_JAX_CKPT_REMOTE  Remote JAX checkpoint root.
                        Default: rvalperga@snellius.surf.nl:/projects/prjs1905/robotics/metaworld/icil_runs/checkpoints
  ICIL_EVAL_CKPT_DIR    Local output root.
                        Default: eval_checkpoints
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -ne 2 ]]; then
  usage >&2
  exit 2
fi

if ! command -v rsync >/dev/null 2>&1; then
  echo "error: rsync not found in PATH" >&2
  exit 1
fi

run_id="$1"
step="$2"

step="${step#step_}"
step="${step%.pkl}"

if [[ ! "$step" =~ ^[0-9]+$ ]]; then
  echo "error: STEP must be numeric or look like step_0267000.pkl; got '$2'" >&2
  exit 2
fi

if [[ ${#step} -lt 7 ]]; then
  step="$(printf "%07d" "$((10#$step))")"
fi

remote_root="${ICIL_JAX_CKPT_REMOTE:-rvalperga@snellius.surf.nl:/projects/prjs1905/robotics/metaworld/icil_runs/checkpoints}"
local_root="${ICIL_EVAL_CKPT_DIR:-eval_checkpoints}"

remote_path="${remote_root%/}/${run_id}/step_${step}.pkl"
local_dir="${local_root%/}/${run_id}/"

mkdir -p "$local_dir"

echo "[get_jax_ckpt] copying:"
echo "  from: $remote_path"
echo "  to:   $local_dir"

rsync -rL --progress "$remote_path" "$local_dir"
